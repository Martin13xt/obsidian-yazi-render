{
  "name": "yazi-exporter",
  "version": "0.2.0",
  "private": true,
  "description": "Obsidian plugin to render active note to Vault-external PNG cache for Yazi.",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "dev": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test": "npm run test:unit"
  },
  "dependencies": {
    "html2canvas": "^1.4.1"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "esbuild": "^0.25.0",
    "luaparse": "^0.3.1",
    "obsidian": "^1.6.7",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  }
}
